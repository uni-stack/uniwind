{
    "name": "uniwind-monorepo",
    "private": true,
    "scripts": {
        "prepare": "husky",
        "build": "turbo build",
        "check:typescript": "turbo check:typescript",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "check:format": "dprint check",
        "precommit": "turbo precommit",
        "test": "turbo test",
        "format": "dprint fmt",
        "circular:check": "turbo circular:check",
        "postinstall": "git update-index --assume-unchanged packages/uniwind/uniwind.css"
    },
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "catalog": {
            "typescript": "5.9.3",
            "@types/bun": "1.3.10",
            "@types/react": "19.2.4",
            "@types/react-dom": "19.2.4",
            "react": "19.2.4",
            "react-dom": "19.2.4",
            "expo": "55.0.4",
            "react-native": "0.83.2",
            "react-native-web": "0.21.2",
            "tailwindcss": "4.2.1",
            "vite": "7.2.6"
        }
    },
    "devDependencies": {
        "typescript": "catalog:",
        "dprint": "0.53.0",
        "eslint": "9.39.1",
        "eslint-config-codemask": "2.2.1",
        "husky": "9.1.7",
        "turbo": "2.8.17"
    },
    "packageManager": "bun@1.3.10",
    "trustedDependencies": [
        "@tailwindcss/oxide"
    ],
    "patchedDependencies": {
        "react-native@0.83.2": "patches/react-native@0.83.2.patch"
    }
}

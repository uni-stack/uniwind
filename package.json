{
    "name": "uniwind-monorepo",
    "private": true,
    "scripts": {
        "prepare": "husky",
        "build": "turbo build",
        "check:typescript": "turbo check:typescript",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "check:format": "dprint check",
        "precommit": "turbo precommit",
        "test": "turbo test",
        "format": "dprint fmt",
        "circular:check": "turbo circular:check",
        "postinstall": "git update-index --assume-unchanged packages/uniwind/uniwind.css"
    },
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*"
        ],
        "catalog": {
            "typescript": "6.0.3",
            "@types/bun": "1.3.14",
            "@types/react": "19.2.15",
            "@types/react-dom": "19.2.3",
            "react": "19.2.3",
            "react-dom": "19.2.3",
            "expo": "56.0.4",
            "react-native": "0.85.3",
            "react-native-web": "0.21.2",
            "tailwindcss": "4.3.0",
            "vite": "8.0.14"
        }
    },
    "devDependencies": {
        "typescript": "catalog:",
        "dprint": "0.54.0",
        "oxlint": "1.67.0",
        "oxlint-tsgolint": "0.23.0",
        "husky": "9.1.7",
        "turbo": "2.9.16"
    },
    "packageManager": "bun@1.3.14",
    "trustedDependencies": [
        "@tailwindcss/oxide"
    ]
}
